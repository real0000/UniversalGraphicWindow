/*
 * @PROJECT_NAME@ - generated by UniversalGraphicWindow project wizard
 *
 * Backend fallback priority:
 *   Windows : D3D12 -> Vulkan -> D3D11 -> OpenGL
 *   Apple   : Metal -> Vulkan -> OpenGL (ES via EAGL on iOS)
 *   Linux   : Vulkan -> OpenGL
 *   Android : Vulkan -> OpenGL (ES)
 */

#include "window.hpp"
#include <cstdio>
#include <vector>

int main() {
    window::Config config;
    config.windows[0].title = "@PROJECT_NAME@";
    config.windows[0].width = 1280;
    config.windows[0].height = 720;
    config.vsync = true;

    static const window::Backend fallback_chain[] = {
#if defined(WINDOW_PLATFORM_WIN32) || defined(WINDOW_PLATFORM_UWP)
        window::Backend::D3D12,
        window::Backend::Vulkan,
        window::Backend::D3D11,
        window::Backend::OpenGL,
#elif defined(WINDOW_PLATFORM_MACOS) || defined(WINDOW_PLATFORM_IOS)
        window::Backend::Metal,
        window::Backend::Vulkan,
        window::Backend::OpenGL,
#elif defined(WINDOW_PLATFORM_ANDROID)
        window::Backend::Vulkan,
        window::Backend::OpenGL,
#else
        window::Backend::Vulkan,
        window::Backend::OpenGL,
#endif
    };

    window::Result result = window::Result::Success;
    std::vector<window::Window*> windows;

    for (window::Backend backend : fallback_chain) {
        config.backend = backend;
        windows = window::Window::create(config, &result);
        if (result == window::Result::Success && !windows.empty()) {
            break;
        }
        printf("Backend %s unavailable (%s), trying next...\n",
               window::backend_to_string(backend),
               window::result_to_string(result));
        for (auto* w : windows) { if (w) w->destroy(); }
        windows.clear();
    }

    if (windows.empty()) {
        printf("Failed to create window with any backend.\n");
        return 1;
    }

    window::Window* win = windows[0];
    window::Graphics* gfx = win->graphics();

    printf("@PROJECT_NAME@ started\n");
    printf("Backend: %s\n", gfx->get_backend_name());
    printf("Device:  %s\n", gfx->get_device_name());
    printf("Size:    %dx%d (DPI %d, %.2fx)\n",
           win->get_width(), win->get_height(),
           win->get_dpi(), win->get_dpi_scale());

    while (!win->should_close()) {
        win->poll_events();
    }

    win->destroy();
    return 0;
}
